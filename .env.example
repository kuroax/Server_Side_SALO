# ========================
# Server
# ========================
NODE_ENV=development
PORT=4000

# ========================
# Database
# ========================
MONGODB_URI=mongodb://127.0.0.1:27017/salo

# ========================
# Auth
# ========================
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# Security
# ========================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# Integrations
# ========================
ANTHROPIC_API_KEY=your_key_from_console.anthropic.com
WEBHOOK_SECRET=your_random_secret_min_16_chars
WHATSAPP_ACCESS_TOKEN=your_meta_access_token

# Secret used by n8n buffer endpoints (push + claim).
# Must match BUFFER_WEBHOOK_SECRET set in the n8n Railway service variables.
# Rotate both values together if compromised.
BUFFER_WEBHOOK_SECRET=your_random_secret_min_16_chars

# How long (ms) Check & Merge waits before claiming the buffer.
# Must be less than the n8n Wait node duration (default: 60000ms).
# Defaults to 55000 if not set. Set to 5000 for local testing.
WHATSAPP_BUFFER_ELAPSED_THRESHOLD_MS=55000

# ========================
# CORS
# ========================
CORS_ORIGIN=http://localhost:3000