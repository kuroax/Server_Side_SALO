{
  "name": "server-side-salo",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL backend for SALO",
  "author": "kuroAX",
  "license": "ISC",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/__tests__/integration",
    "eval": "npx tsx src/evals/run.ts",
    "migrate:encrypt-tokens": "npx tsx src/scripts/migrate-encrypt-tokens.ts",
    "migrate:add-agent-config": "npx tsx src/scripts/migrate-add-agent-config.ts",
    "migrate:sales-instructions": "npx tsx src/scripts/migrate-sales-instructions.ts",
    "migrate:agentconfig-structured": "npx tsx src/scripts/migrate-agentconfig-structured.ts",
    "migrate:boutique-slugs": "npx tsx src/scripts/migrate-boutique-slugs.ts",
    "create-boutique": "npx tsx src/scripts/create-boutique.ts"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/schema": "^10.0.31",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.13.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
